                        {
                            auto res = smartFind(lot, b);
                            if (res[0] == -1) addToast("Block " + std::to_string(b) + " is FULL!", C_RED);
                            else
                            {
                                int rr = res[0], ss = res[1];
                                delete[] lot.ptr[b - 1][rr - 1][ss - 1];
                                lot.ptr[b - 1][rr - 1][ss - 1] = new char[8];
                                for (int ci = 0; ci < 7; ci++)
                                    lot.ptr[b - 1][rr - 1][ss - 1][ci] = pl[static_cast<size_t>(ci)];
                                lot.ptr[b - 1][rr - 1][ss - 1][7] = '\0';
                                addToast("Smart: " + pl + " -> B" + std::to_string(b) + " R" + std::to_string(rr) + " S" + std::to_string(ss), C_YELLOW);
                                highlightB = b; highlightR = rr; highlightS = ss; highlightTimer = 5.f;
                                panel = PNL_VIEW;
                            }
                        }
                    }

                    if (panel == PNL_GROW && btnGrow.clicked(mouse))
                    {
                        int b = grBlock.value.empty() ? 0 : std::stoi(grBlock.value);
                        int r = grRow.value.empty() ? 0 : std::stoi(grRow.value);
                        int ns = grNew.value.empty() ? 0 : std::stoi(grNew.value);
                        if (b<1 || b>lot.b)             addToast("Invalid block!", C_RED);
                        else if (r<1 || r>lot.rpb[b - 1])      addToast("Invalid row!", C_RED);
                        else if (ns <= lot.spb[b - 1][r - 1])    addToast("New count must be > " + std::to_string(lot.spb[b - 1][r - 1]), C_RED);
                        else { growRow(lot, b, r, ns); addToast("Grew to " + std::to_string(ns) + " slots", C_GREEN); panel = PNL_VIEW; }
                    }

                    if (panel == PNL_SHRINK && btnShrink.clicked(mouse))
                    {
                        int b = shBlock.value.empty() ? 0 : std::stoi(shBlock.value);
                        int r = shRow.value.empty() ? 0 : std::stoi(shRow.value);
                        int ns = shNew.value.empty() ? 0 : std::stoi(shNew.value);
                        if (b<1 || b>lot.b)             addToast("Invalid block!", C_RED);
                        else if (r<1 || r>lot.rpb[b - 1])      addToast("Invalid row!", C_RED);
                        else if (ns >= lot.spb[b - 1][r - 1])    addToast("New count must be < " + std::to_string(lot.spb[b - 1][r - 1]), C_RED);
                        else if (!shrinkRow(lot, b, r, ns))   addToast("Cannot shrink: tail slots occupied!", C_RED);
                        else { addToast("Shrunk to " + std::to_string(ns) + " slots", C_GREEN); panel = PNL_VIEW; }
                    }
                }
            }
        } // pollEvent
        highlightTimer -= dt;
        if (highlightTimer <= 0.f) highlightB = highlightR = highlightS = -1;
        toasts.erase(
            std::remove_if(toasts.begin(), toasts.end(),
                [&dt](Toast& t) { t.timer -= dt; return t.timer <= 0.f; }),
            toasts.end());

        window.clear(C_BG);

        if (screen == SCR_SETUP)
        {
            // Grid background
            for (int gx = 0; gx < 1280; gx += 40)
            {
                sf::RectangleShape l({ 1.f,780.f });
                l.setPosition(static_cast<float>(gx), 0.f);
                l.setFillColor(sf::Color(0, 212, 255, 10)); window.draw(l);
            }
            for (int gy = 0; gy < 780; gy += 40)
            {
                sf::RectangleShape l({ 1280.f,1.f });
                l.setPosition(0.f, static_cast<float>(gy));
                l.setFillColor(sf::Color(0, 212, 255, 10)); window.draw(l);
            }

            
            {
                sf::Text t; t.setFont(font);
                t.setString("SMART PARKING SYSTEM");
                t.setCharacterSize(36); t.setFillColor(C_ACCENT); t.setLetterSpacing(2.f);
                sf::FloatRect tb = t.getLocalBounds();
                t.setPosition((1280.f - tb.width) / 2.f, 130.f); window.draw(t);

                sf::Text sub; sub.setFont(font);
                sub.setString("CONFIGURE YOUR PARKING LOT STRUCTURE");
                sub.setCharacterSize(13); sub.setFillColor(C_DIM);
                sf::FloatRect sb = sub.getLocalBounds();
                sub.setPosition((1280.f - sb.width) / 2.f, 185.f); window.draw(sub);
            }
            window.draw(makeRect(200.f, 220.f, 880.f, 1.f, sf::Color(0, 212, 255, 60)));

            {
                sf::Text s1; s1.setFont(font);
                s1.setString("STEP 1 - NUMBER OF BLOCKS");
                s1.setCharacterSize(12); s1.setFillColor(C_DIM);
                s1.setPosition(540.f, 260.f); window.draw(s1);
            }
            inpBlocks.draw(window);
            btnNext.draw(window, mouse);

            if (setupGenerated)
            {
                sf::Text s2; s2.setFont(font);
                s2.setString("STEP 2 - ROWS PER BLOCK  (slots default to 4 per row)");
                s2.setCharacterSize(12); s2.setFillColor(C_DIM);
                s2.setPosition(100.f, 405.f); window.draw(s2);
                for (auto& ri : setupRowInputs) ri.draw(window);
                btnCreate.draw(window, mouse);
            }
        }

        else
        {
            const float PX = 220.f, PY = 70.f, PW = 1060.f;
            const float FY = PY + 130.f;

            
            window.draw(makeRect(0.f, 0.f, 1280.f, 60.f, sf::Color(10, 18, 35), C_BORDER, 0.f));
            window.draw(makeRect(0.f, 59.f, 1280.f, 1.f, C_ACCENT));
            {
                
                sf::Text t; t.setFont(font);
                t.setString("[ SMART PARKING SYSTEM ]");
                t.setCharacterSize(20); t.setFillColor(C_ACCENT);
                t.setPosition(220.f, 18.f); window.draw(t);
            }

          
            if (lot.ptr)
            {
                int total, occ, fr; getStats(lot, total, occ, fr);
                float pct = (total > 0) ? (100.f * static_cast<float>(occ) / static_cast<float>(total)) : 0.f;
                auto statTxt = [&](const std::string& s, float x, sf::Color c) {
                    sf::Text t; t.setFont(font); t.setString(s);
                    t.setCharacterSize(12); t.setFillColor(c); t.setPosition(x, 22.f);
                    window.draw(t);
                    };
                statTxt("FREE: " + std::to_string(fr), 500.f, C_GREEN);
                statTxt("OCC: " + std::to_string(occ), 640.f, C_RED);
                statTxt("TOTAL: " + std::to_string(total), 760.f, C_ACCENT);
                char buf[32];
                std::snprintf(buf, sizeof(buf), "%.0f%% FULL", static_cast<double>(pct));
                statTxt(std::string(buf), 900.f, C_YELLOW);
            }

            
            window.draw(makeRect(0.f, 60.f, 215.f, 720.f, C_PANEL, C_BORDER, 0.f));
            window.draw(makeRect(215.f, 60.f, 1.f, 720.f, C_BORDER));
            {
                sf::Text t; t.setFont(font); t.setString("OPERATIONS");
                t.setCharacterSize(10); t.setFillColor(C_DIM); t.setLetterSpacing(3.f);
                t.setPosition(SBX + 5.f, 110.f); window.draw(t);
                window.draw(makeRect(SBX, 125.f, SBW, 1.f, C_BORDER));
            }
            for (int i = 0; i < 7; i++)
            {
                if (static_cast<int>(panel) == i)
                {
                    sidebtns[i].box.setFillColor(sf::Color(0, 212, 255, 25));
                    sidebtns[i].box.setOutlineColor(C_ACCENT);
                }
                sidebtns[i].draw(window, mouse);
            }

            {
                const char* ptitles[] = { "VIEW LOT","PARK VEHICLE","UNPARK VEHICLE",
                                        "FIND VEHICLE","SMART PARK","GROW SLOTS","SHRINK SLOTS" };
                sf::Text t; t.setFont(font);
                t.setString(ptitles[static_cast<int>(panel)]);
                t.setCharacterSize(16); t.setFillColor(C_ACCENT); t.setLetterSpacing(2.f);
                t.setPosition(PX + 15.f, PY + 12.f); window.draw(t);
                window.draw(makeRect(PX + 15.f, PY + 38.f, PW - 30.f, 1.f, C_BORDER));
            }

            if (!resultMsg.empty())
            {
                sf::Text rm; rm.setFont(font); rm.setString(resultMsg);
                rm.setCharacterSize(13); rm.setFillColor(resultColor);
                rm.setPosition(PX + 15.f, PY + 50.f); window.draw(rm);
            }

            if (panel == PNL_VIEW && lot.ptr)
            {
                float startX = PX + 15.f, startY = PY + 70.f - viewScrollY;
                float blockW = PW - 30.f, curY = startY;

                for (int bi = 0; bi < lot.b; bi++)
                {
                   
                    float blockH = 30.f + static_cast<float>(lot.rpb[bi]) * 68.f;
                    window.draw(makeRect(startX, curY, blockW, blockH, C_CARD, C_BORDER));
                    window.draw(makeRect(startX, curY, blockW, 2.f, sf::Color(0, 212, 255, 80)));

                  
                    {
                        sf::Text bt; bt.setFont(font);
                        bt.setString("BLOCK " + std::to_string(bi + 1));
                        bt.setCharacterSize(14); bt.setFillColor(C_ACCENT); bt.setLetterSpacing(2.f);
                        bt.setPosition(startX + 12.f, curY + 7.f); window.draw(bt);
                    }

                    // Occupancy bar
                    {
                        int btot = 0, bocc = 0;
                        for (int rr = 0; rr < lot.rpb[bi]; rr++)
                            for (int ss = 0; ss < lot.spb[bi][rr]; ss++)
                            {
                                btot++; if (!isSlotEmpty(lot.ptr, bi + 1, rr + 1, ss + 1))bocc++;
                            }

                        float barW = 150.f, bx = startX + blockW - barW - 15.f, by = curY + 11.f;
                        window.draw(makeRect(bx, by, barW, 8.f, sf::Color(20, 30, 40), C_BORDER));
                        
                        float fillW = (btot > 0) ? (barW * static_cast<float>(bocc) / static_cast<float>(btot)) : 0.f;
                        sf::Color fillC = (bocc == btot) ? C_RED : (bocc > btot / 2) ? C_YELLOW : C_GREEN;
                        window.draw(makeRect(bx, by, fillW, 8.f, fillC, sf::Color(0, 0, 0, 0)));
                        char buf2[32]; std::snprintf(buf2, sizeof(buf2), "%d/%d", bocc, btot);
                        sf::Text bc2; bc2.setFont(font); bc2.setString(buf2);
                        bc2.setCharacterSize(11); bc2.setFillColor(fillC);
                        bc2.setPosition(bx + barW + 6.f, by - 2.f); window.draw(bc2);
                    }

                    float ry = curY + 30.f;
                    for (int ri = 0; ri < lot.rpb[bi]; ri++)
                    {
                        sf::Text rl; rl.setFont(font);
                        rl.setString("R" + std::to_string(ri + 1));
                        rl.setCharacterSize(11); rl.setFillColor(C_DIM);
                        rl.setPosition(startX + 8.f, ry + 20.f); window.draw(rl);

                        window.draw(makeRect(startX + 30.f, ry + 26.f, blockW - 40.f, 16.f, sf::Color(15, 20, 30)));
                        for (float dx = startX + 50.f; dx < startX + blockW - 40.f; dx += 30.f)
                            window.draw(makeRect(dx, ry + 32.f, 15.f, 4.f, sf::Color(255, 215, 0, 60)));

                        const float slotW = 60.f, slotH = 52.f, gap = 6.f;
                        float sx = startX + 38.f;
                        for (int si = 0; si < lot.spb[bi][ri]; si++)
                        {
                            bool empty = isSlotEmpty(lot.ptr, bi + 1, ri + 1, si + 1);
                            bool isHL = (bi + 1 == highlightB && ri + 1 == highlightR && si + 1 == highlightS);
                           
                            float slotX = sx + static_cast<float>(si) * (slotW + gap), slotY = ry + 5.f;
                            sf::Color bg = empty ? C_EMPTY_BG : C_OCC_BG;
                            sf::Color brd = empty ? C_GREEN : C_RED;
                            if (isHL) { bg = sf::Color(255, 215, 0, 40); brd = C_YELLOW; }
                            window.draw(makeRect(slotX, slotY, slotW, slotH, bg, brd, isHL ? 2.f : 1.f));

                            sf::Text ico; ico.setFont(font);
                            ico.setString(empty ? "P" : "CAR");
                            ico.setCharacterSize(empty ? 18u : 12u);
                            ico.setFillColor(empty ? sf::Color(0, 255, 136, 60) : sf::Color(255, 80, 80, 200));
                            sf::FloatRect ib = ico.getLocalBounds();
                            ico.setPosition(slotX + (slotW - ib.width) / 2.f, slotY + 5.f); window.draw(ico);

                            if (!empty)
                            {
                                sf::Text pl2; pl2.setFont(font);
                                pl2.setString(lot.ptr[bi][ri][si]);
                                pl2.setCharacterSize(9); pl2.setFillColor(C_TEXT);
                                sf::FloatRect pb = pl2.getLocalBounds();
                                pl2.setPosition(slotX + (slotW - pb.width) / 2.f, slotY + 30.f);
                                window.draw(pl2);
                            }

                            sf::Text sn; sn.setFont(font);
                            sn.setString("S" + std::to_string(si + 1));
                            sn.setCharacterSize(9); sn.setFillColor(C_DIM);
                            sf::FloatRect snb = sn.getLocalBounds();
                            sn.setPosition(slotX + (slotW - snb.width) / 2.f, slotY + 42.f);
                            window.draw(sn);
                        }
                        ry += 68.f;
                    }
                    curY += blockH + 20.f;
                }
            }

            auto drawFormBg = [&]() {
                window.draw(makeRect(PX + 10.f, PY + 60.f, PW - 20.f, 190.f, C_CARD, C_BORDER));
                };

            if (panel == PNL_PARK)
            {
                drawFormBg();
                setPos(pBlock, PX + 20.f, FY); setPos(pRow, PX + 160.f, FY);
                setPos(pSlot, PX + 300.f, FY); setPos(pPlate, PX + 440.f, FY);
                pBlock.draw(window); pRow.draw(window); pSlot.draw(window); pPlate.draw(window);
                setPos(btnPark, PX + 20.f, FY + 50.f); btnPark.draw(window, mouse);
            }
            if (panel == PNL_UNPARK)
            {
                drawFormBg();
                setPos(upBlock, PX + 20.f, FY); setPos(upRow, PX + 160.f, FY); setPos(upSlot, PX + 300.f, FY);
                upBlock.draw(window); upRow.draw(window); upSlot.draw(window);
                setPos(btnUnpark, PX + 20.f, FY + 50.f); btnUnpark.draw(window, mouse);
            }
            if (panel == PNL_FIND)
            {
                drawFormBg();
                setPos(fPlate, PX + 20.f, FY); fPlate.draw(window);
                setPos(btnFind, PX + 20.f, FY + 50.f); btnFind.draw(window, mouse);
            }
            if (panel == PNL_SMART)
            {
                drawFormBg();
                setPos(smBlock, PX + 20.f, FY); setPos(smPlate, PX + 160.f, FY);
                smBlock.draw(window); smPlate.draw(window);
                setPos(btnSmart, PX + 20.f, FY + 50.f); btnSmart.draw(window, mouse);
                sf::Text info; info.setFont(font);
                info.setString("Finds the nearest empty slot to block entrance and parks automatically.");
                info.setCharacterSize(11); info.setFillColor(C_DIM);
                info.setPosition(PX + 20.f, FY + 100.f); window.draw(info);
            }
            if (panel == PNL_GROW)
            {
                drawFormBg();
                setPos(grBlock, PX + 20.f, FY); setPos(grRow, PX + 160.f, FY); setPos(grNew, PX + 300.f, FY);
                grBlock.draw(window); grRow.draw(window); grNew.draw(window);
                setPos(btnGrow, PX + 20.f, FY + 50.f); btnGrow.draw(window, mouse);
            }
            if (panel == PNL_SHRINK)
            {
                drawFormBg();
                setPos(shBlock, PX + 20.f, FY); setPos(shRow, PX + 160.f, FY); setPos(shNew, PX + 300.f, FY);
                shBlock.draw(window); shRow.draw(window); shNew.draw(window);
                setPos(btnShrink, PX + 20.f, FY + 50.f); btnShrink.draw(window, mouse);
                sf::Text warn; warn.setFont(font);
                warn.setString("WARNING: Only trailing empty slots can be removed.");
                warn.setCharacterSize(11); warn.setFillColor(C_RED);
                warn.setPosition(PX + 20.f, FY + 100.f); window.draw(warn);
            }
        } 
        {
            float ty = 80.f;
            for (auto& t : toasts)
            {
            
                sf::Uint8 alpha = static_cast<sf::Uint8>(std::min(1.f, t.timer) * 255.f);
                window.draw(makeRect(1280.f - 330.f, ty, 315.f, 46.f,
                    sf::Color(10, 18, 35, alpha), t.color, 1.f));
                sf::Text tt; tt.setFont(font); tt.setString(t.msg);
                tt.setCharacterSize(12);
                tt.setFillColor(sf::Color(t.color.r, t.color.g, t.color.b, alpha));
                tt.setPosition(1280.f - 322.f, ty + 14.f); window.draw(tt);
                ty += 54.f;
            }
        }

        window.display();
    }

    freeLot(lot);
    return 0;
}
