//  DATA
struct ParkingLot {
    int      b = 0;
    char**** ptr = nullptr;
    int* rpb = nullptr;
    int** spb = nullptr;
};


//  CORE LOGIC
void emptySlot(char**** ptr, int b, int r, int s)
{
    ptr[b][r][s] = new char[6];
    const char* E = "EMPTY";
    for (int i = 0; i < 6; i++) ptr[b][r][s][i] = E[i];
}

bool isSlotEmpty(char**** ptr, int block, int row, int slot)
{
    const char* E = "EMPTY";
    for (int j = 0; j < 5; j++)
        if (ptr[block - 1][row - 1][slot - 1][j] != E[j]) return false;
    return true;
}

void allocateLot(ParkingLot& lot,
    const std::vector<int>& rows,
    const std::vector<std::vector<int>>& slots)
{
    lot.rpb = new int[lot.b];
    lot.spb = new int* [lot.b];
    for (int i = 0; i < lot.b; i++)
    {
        lot.rpb[i] = rows[i];
        lot.ptr[i] = new char** [rows[i]];
        lot.spb[i] = new int[rows[i]];
        for (int j = 0; j < rows[i]; j++)
        {
            lot.spb[i][j] = slots[i][j];
            lot.ptr[i][j] = new char* [slots[i][j]];
            for (int k = 0; k < slots[i][j]; k++)
                emptySlot(lot.ptr, i, j, k);
        }
    }
}

void freeLot(ParkingLot& lot)
{
    if (!lot.ptr) return;
    for (int i = 0; i < lot.b; i++)
    {
        for (int j = 0; j < lot.rpb[i]; j++)
        {
            for (int k = 0; k < lot.spb[i][j]; k++)
                delete[] lot.ptr[i][j][k];
            delete[] lot.ptr[i][j];
        }
        delete[] lot.ptr[i];
        delete[] lot.spb[i];
    }
    delete[] lot.ptr;  lot.ptr = nullptr;
    delete[] lot.rpb;  lot.rpb = nullptr;
    delete[] lot.spb;  lot.spb = nullptr;
}

std::vector<int> findCar(ParkingLot& lot, const std::string& plate)
{
    for (int i = 0; i < lot.b; i++)
        for (int j = 0; j < lot.rpb[i]; j++)
            for (int k = 0; k < lot.spb[i][j]; k++)
            {
                if (isSlotEmpty(lot.ptr, i + 1, j + 1, k + 1)) continue;
                if (std::string(lot.ptr[i][j][k]) == plate)
                    return { i + 1, j + 1, k + 1 };
            }
    return { -1, -1, -1 };
}

std::vector<int> smartFind(ParkingLot& lot, int block)
{
    int bestRow = -1, bestSlot = -1;
    double minDis = 1e9;
    for (int i = 0; i < lot.rpb[block - 1]; i++)
        for (int j = 0; j < lot.spb[block - 1][i]; j++)
            if (isSlotEmpty(lot.ptr, block, i + 1, j + 1))
            {
                double x = static_cast<double>(j) * 8.0;
                double y = static_cast<double>(i) * 16.0;
                double dis = std::sqrt(x * x + y * y);
                if (dis < minDis) { minDis = dis; bestRow = i + 1; bestSlot = j + 1; }
            }
    return { bestRow, bestSlot };
}


static void safeCopyPlate(char*& dest, const char* src)
{
   
    int len = static_cast<int>(strlen(src));
    dest = new char[len + 1];
    for (int c = 0; c <= len; c++) dest[c] = src[c];
}

void growRow(ParkingLot& lot, int block, int row, int newSlots)
{
    int old = lot.spb[block - 1][row - 1];

    // Allocate new array
    char** N = new char* [newSlots];

   
    for (int i = 0; i < newSlots; i++)
    {
        N[i] = new char[6];
        const char* E = "EMPTY";
        for (int x = 0; x < 6; x++) N[i][x] = E[x];
    }

    
    for (int i = 0; i < old; i++)
    {
        if (!isSlotEmpty(lot.ptr, block, row, i + 1))
        {
            delete[] N[i];
            safeCopyPlate(N[i], lot.ptr[block - 1][row - 1][i]);
        }
        delete[] lot.ptr[block - 1][row - 1][i];
    }

    delete[] lot.ptr[block - 1][row - 1];
    lot.ptr[block - 1][row - 1] = N;
    lot.spb[block - 1][row - 1] = newSlots;
}

bool shrinkRow(ParkingLot& lot, int block, int row, int newSlots)
{
    int old = lot.spb[block - 1][row - 1];
    for (int i = newSlots; i < old; i++)
        if (!isSlotEmpty(lot.ptr, block, row, i + 1)) return false;

    char** N = new char* [newSlots];
    for (int i = 0; i < newSlots; i++)
    {
        N[i] = new char[6];
        const char* E = "EMPTY";
        for (int x = 0; x < 6; x++) N[i][x] = E[x];
    }
    for (int i = 0; i < newSlots; i++)
    {
        if (!isSlotEmpty(lot.ptr, block, row, i + 1))
        {
            delete[] N[i];
            safeCopyPlate(N[i], lot.ptr[block - 1][row - 1][i]);
        }
    }
    for (int i = 0; i < old; i++) delete[] lot.ptr[block - 1][row - 1][i];
    delete[] lot.ptr[block - 1][row - 1];
    lot.ptr[block - 1][row - 1] = N;
    lot.spb[block - 1][row - 1] = newSlots;
    return true;
}

void getStats(ParkingLot& lot, int& total, int& occupied, int& free_)
{
    total = occupied = free_ = 0;
    for (int i = 0; i < lot.b; i++)
        for (int j = 0; j < lot.rpb[i]; j++)
            for (int k = 0; k < lot.spb[i][j]; k++)
            {
                total++;
                if (!isSlotEmpty(lot.ptr, i + 1, j + 1, k + 1)) occupied++;
                else free_++;
            }
}

//  SHAPE HELPER
sf::RectangleShape makeRect(float x, float y, float w, float h,
    sf::Color fill,
    sf::Color outline = sf::Color(25, 58, 92),
    float thick = 1.f)
{
    sf::RectangleShape r({ w, h });
    r.setPosition(x, y);
    r.setFillColor(fill);
    r.setOutlineColor(outline);
    r.setOutlineThickness(thick);
    return r;
}



