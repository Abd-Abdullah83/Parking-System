//  TEXT INPUT
struct TextInput
{
    sf::RectangleShape box;
    sf::Text           label, text;
    std::string        value;
    bool               focused = false;
    bool               numbersOnly = false;

    void draw(sf::RenderWindow& w)
    {
        box.setOutlineColor(focused ? C_ACCENT : C_BORDER);
        box.setFillColor(focused ? sf::Color(0, 212, 255, 15) : sf::Color(5, 10, 20));
        w.draw(box); w.draw(label);
        text.setString(value + (focused ? "|" : ""));
        w.draw(text);
    }

    void handleEvent(const sf::Event& ev)
    {
        if (ev.type != sf::Event::TextEntered || !focused) return;
        if (ev.text.unicode == 8 && !value.empty()) { value.pop_back(); return; }
        if (ev.text.unicode == 13) { focused = false;  return; }
        if (ev.text.unicode >= 32 && ev.text.unicode < 127)
        {
            char c = static_cast<char>(ev.text.unicode);
            if (numbersOnly && (c < '0' || c > '9')) return;
            if (value.size() < 20)
                value += static_cast<char>(toupper(static_cast<unsigned char>(c)));
        }
    }

    bool contains(sf::Vector2f p) const { return box.getGlobalBounds().contains(p); }
};

struct Button
{
    sf::RectangleShape box;
    sf::Text           label;
    sf::Color          normalColor, hoverColor, outlineNormal, outlineHover;

    void draw(sf::RenderWindow& w, sf::Vector2f mouse)
    {
        bool hov = box.getGlobalBounds().contains(mouse);
        box.setFillColor(hov ? hoverColor : normalColor);
        box.setOutlineColor(hov ? outlineHover : outlineNormal);
        w.draw(box); w.draw(label);
    }
    bool clicked(sf::Vector2f p) const { return box.getGlobalBounds().contains(p); }
};

struct Toast { std::string msg; sf::Color color; float timer; };

TextInput makeInput(const sf::Font& font,
    float x, float y, float w, float h,
    const std::string& lbl, bool numOnly = false)
{
    TextInput inp;
    inp.box = makeRect(x, y, w, h, sf::Color(5, 10, 20), C_BORDER);
    inp.label.setFont(font); inp.label.setString(lbl);
    inp.label.setCharacterSize(11); inp.label.setFillColor(C_DIM);
    inp.label.setPosition(x, y - 17.f);
    inp.text.setFont(font); inp.text.setCharacterSize(14);
    inp.text.setFillColor(C_ACCENT); inp.text.setPosition(x + 8.f, y + 8.f);
    inp.numbersOnly = numOnly;
    return inp;
}

Button makeBtn(const sf::Font& font,
    float x, float y, float w, float h,
    const std::string& lbl,
    sf::Color fill = sf::Color(0, 212, 255, 20),
    sf::Color hover = sf::Color(0, 212, 255, 50),
    sf::Color outNormal = C_ACCENT,
    sf::Color outHover = C_ACCENT)
{
    Button b;
    b.box = makeRect(x, y, w, h, fill, outNormal);
    b.normalColor = fill; b.hoverColor = hover;
    b.outlineNormal = outNormal; b.outlineHover = outHover;
    b.label.setFont(font); b.label.setString(lbl);
    b.label.setCharacterSize(13); b.label.setFillColor(outNormal);
    sf::FloatRect tb = b.label.getLocalBounds();
    b.label.setPosition(x + (w - tb.width) / 2.f, y + (h - tb.height) / 2.f - 2.f);
    return b;
}


void setPos(TextInput& inp, float x, float y)
{
    inp.box.setPosition(x, y);
    inp.label.setPosition(x, y - 17.f);
    inp.text.setPosition(x + 8.f, y + 8.f);
}


void setPos(Button& b, float x, float y)
{
    b.box.setPosition(x, y);
    sf::FloatRect lb = b.label.getLocalBounds();
    float bw = b.box.getSize().x, bh = b.box.getSize().y;
    b.label.setPosition(x + (bw - lb.width) / 2.f, y + (bh - lb.height) / 2.f - 2.f);
}


